GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
DB_PATH=trade_validation.db
CHECKPOINT_DB_PATH=trade_validation_checkpoints.db
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.5
MAX_TOKENS_PER_RUN=10000

# IMAP inbox watcher. Leave IMAP_HOST empty to keep the watcher disabled.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_SECONDS=60

# SMTP reply sender. Replies are only sent by the explicit send-reply endpoint.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
